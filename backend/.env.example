# 모드 설정
# USE_MOCK=true : Upstage Solar 단독 (번역 + 팩트체크, 개발/데모용)
# USE_MOCK=false: Upstage Solar + Tavily 웹 검색 (팩트체크 강화, 프로덕션용)
USE_MOCK=true

# Upstage Solar API 키 — 번역 및 팩트체크 (항상 필요)
# 발급: https://console.upstage.ai
UPSTAGE_API_KEY=your_upstage_api_key_here

# Tavily 웹 검색 API 키 — USE_MOCK=false 시 팩트체크 검색에 사용
# 미설정 시 자체 지식 fallback으로 동작 (검색 비활성화)
# 발급: https://tavily.com
TAVILY_API_KEY=your_tavily_api_key_here
