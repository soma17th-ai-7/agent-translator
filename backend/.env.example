# 모드 설정
# USE_MOCK=true : Upstage API로 번역 및 팩트체크 (개발/데모용, 백엔드만 실행하면 됨)
# USE_MOCK=false: DeepL(번역) + Claude+Tavily(팩트체크) (프로덕션용)
USE_MOCK=true

# Upstage API 키 (USE_MOCK=true 시 필요)
UPSTAGE_API_KEY=your_upstage_api_key_here

# DeepL API 키 (USE_MOCK=false 시 필요)
# 무료 티어: https://www.deepl.com/pro-api
DEEPL_API_KEY=your_deepl_api_key_here

# Anthropic API 키 (USE_MOCK=false 시 필요)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Tavily 웹 검색 API 키 (USE_MOCK=false 시 필요)
# 무료 티어: https://tavily.com
TAVILY_API_KEY=your_tavily_api_key_here
