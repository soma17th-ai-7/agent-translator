# DeepL API 키
# 무료 티어: https://www.deepl.com/pro-api (Free plan)
# 무료 티어 사용 시 API URL이 api-free.deepl.com 으로 설정됨 (services/deepl.py 참고)
DEEPL_API_KEY=your_deepl_api_key_here

# Anthropic API 키
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Tavily 웹 검색 API 키 (에이전트 웹 검색용)
# 무료 티어: https://tavily.com
TAVILY_API_KEY=your_tavily_api_key_here
